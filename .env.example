# GitHub Container Registry configuration
GITHUB_USER=w9labs

# W9 Tools Configuration
W9_TOOLS_BASE_URL=https://tools.w9.nu
W9_TOOLS_PORT=10105

# Database
DATABASE_URL=sqlite:/app/data/w9-tools.db

# w9-db (OAuth / Identity Provider)
W9_DB_API_URL=https://db.w9.nu
W9_DB_ISSUER_URL=https://db.w9.nu
W9_DB_API_TOKEN=your-w9-db-api-token
W9_DB_PORT=8082
W9_DB_DATABASE_URL=sqlite:/app/data/w9.db
W9_DB_JWT_SECRET=change-me-in-production

# JWT Secret (change this in production!)
JWT_SECRET=your-jwt-secret-change-me

# Email Configuration
W9_MAIL_API_URL=https://w9.nu
W9_MAIL_API_TOKEN=your-w9-mail-api-token
W9_TOOLS_EMAIL_FROM=W9 Tools <no-reply@tools.w9.nu>
W9_TOOLS_PASSWORD_RESET_URL=https://tools.w9.nu/reset-password
W9_TOOLS_VERIFICATION_URL=https://tools.w9.nu/verify

# QR Code Logo (optional - path inside container)
QR_LOGO_PATH=

# Turnstile (Cloudflare CAPTCHA)
W9_TOOLS_TURNSTILE_SECRET=your-turnstile-secret
